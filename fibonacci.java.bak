import java.util.Scanner;
class fibonacci 
{
	public static void main(String[] args) 
	{
		Scanner sc=new Scanner(System.in);
		System.out.println("Enter any number:");
		int n=sc.nextInt();
		
		int a=0,b=1;
		System.out.println("Fibonacci Series:");
		for(int i=1;i<=n;i++)
		{
			
		
			int c=a+b;
			a=b;
			b=c;
			
			System.out.print(a+" ");
		}
			
	}
}
