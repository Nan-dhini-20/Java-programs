class spyNum 
{
	public static void main(String[] args)
	{
		int n=1124;
		int sum=0;
		int mul=1;
		while(n>0)
		{
			int ld=n%10;
			n=n/10;
			sum+=ld;
			mul*=ld;
			
		}
		System.out.println("Sum of digit:" +sum);
		System.out.println("Multiple of digit:" +mul);
		if(sum==mul){
			
			System.out.println("Spy Num");
		}
		else
			System.out.println("Not a Spy Num");
			
		
		
	}
}
